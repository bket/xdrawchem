#!/usr/bin/make -f
# Debian rules file for xdrawchem
# Uses debhelper 13 + cmake buildsystem

export DH_VERBOSE = 1
export DEB_BUILD_MAINT_OPTIONS = hardening=+all
# tst_smiles requires a Qt platform plugin for QApplication
export QT_QPA_PLATFORM = offscreen

%:
	dh $@ --buildsystem=cmake --builddirectory=build-deb

override_dh_auto_configure:
	dh_auto_configure -- \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DRINGHOME=/usr/share/xdrawchem

override_dh_auto_test:
	cd build-deb && ctest --output-on-failure -j$(nproc)

override_dh_auto_install:
	DESTDIR=$(CURDIR)/debian/tmp cmake --install build-deb --prefix /usr
